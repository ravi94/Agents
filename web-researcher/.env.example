# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_SUMMARIZER_MODEL=llama3.1:8b

# SearXNG — point this at your running instance
SEARXNG_URL=http://localhost:8080

# Agent behavior
MAX_ITERATIONS=12
MAX_RESULTS_PER_SEARCH=8
REQUEST_TIMEOUT_SECONDS=20
MAX_PAGE_CHARS=12000

# Observability — opt-in (also toggleable with --trace on the CLI)
TRACING_ENABLED=false
PHOENIX_HOST=127.0.0.1
PHOENIX_PORT=6006
PHOENIX_PROJECT_NAME=web-researcher
# Set this to a standalone `phoenix serve` instance to persist traces and keep
# the UI alive after the CLI exits. Leave unset for embedded (in-memory) mode.
# PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
