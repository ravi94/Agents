# Copy this file to `.env` and fill in the values you have. `jobhunter`
# loads `.env` automatically (from the current directory or a parent) on
# every run; real `export`ed environment variables always take precedence
# over `.env`. All of these are optional — a missing credential just skips
# the corresponding source (see README.md).

# App data directory (profile.json, prefs.yaml, jobs.db, cache/, logs/).
# JOBHUNTER_HOME=./data

# JSearch (RapidAPI job search aggregator).
JSEARCH_API_KEY=

# Adzuna (India job search).
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ntfy.sh topic for push notifications (optional): whole-run failures, and,
# since M3, a push on every job that clears prefs.yaml's alerting.score_threshold.
# Pick something long/unpredictable — ntfy.sh topics are public by name.
# JOBHUNTER_NTFY_TOPIC=
