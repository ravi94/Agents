# --- LLM (Ollama, OpenAI-compatible) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
MODEL_NAME=qwen3:27b
# Tool calling: auto (default) tries native then falls back to prompt-parsed JSON.
# Force with: native | prompt
TOOL_MODE=auto

# --- Search provider ---
# duckduckgo (default, no key) | serpapi (requires SERPAPI_API_KEY)
SEARCH_PROVIDER=duckduckgo
SERPAPI_API_KEY=

# --- Search throttling + cache (helps avoid DuckDuckGo anti-bot throttling) ---
# Minimum seconds between web_search HTTP requests (DDG throttles bursts).
SEARCH_MIN_INTERVAL_SECONDS=2.0
# Extra random 0..N seconds added per request so calls aren't perfectly periodic.
SEARCH_JITTER_SECONDS=1.0
# Cache search results per day so re-runs don't re-hit the backend. true|false
SEARCH_CACHE=true
# Where to store the daily cache (default: <project>/.search_cache)
SEARCH_CACHE_DIR=

# --- Agent guardrails ---
MAX_ITERATIONS=8
# Allow one search per holding without hitting the cap (raise for large portfolios).
MAX_TOOL_CALLS=60
# Throttling spaces searches out, so a full run needs more wall-clock time.
RUN_TIMEOUT_SECONDS=600
FETCH_CHAR_BUDGET=8000

# --- Delivery ---
# email (default) sends via SMTP | file writes summary-<date>.md to OUTPUT_DIR
DELIVERY_MODE=email
# Directory for the summary file when DELIVERY_MODE=file (defaults to project root)
OUTPUT_DIR=

# --- Email delivery (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
