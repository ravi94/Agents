# --- LLM (Ollama, OpenAI-compatible) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
MODEL_NAME=qwen3:27b
# Tool calling: auto (default) tries native then falls back to prompt-parsed JSON.
# Force with: native | prompt
TOOL_MODE=auto

# --- Portfolio ---
# Holdings file to load (relative paths resolve against the project root).
# Defaults to holdings.yaml. A --holdings CLI flag, if passed, overrides this.
HOLDINGS_FILE=holdings.yaml

# --- Search provider ---
# searxng (default, no key — needs a local SearXNG; see mcp/web_search) | serpapi
SEARCH_PROVIDER=searxng
SERPAPI_API_KEY=

# --- SearXNG backend ---
# Base URL of the local SearXNG instance (same one the web_search MCP uses).
SEARXNG_URL=http://localhost:8080
# Throttle protection: token-bucket spacing + retry/backoff on 429/5xx.
SEARXNG_RATE_LIMIT_RPS=1.0
SEARXNG_RATE_LIMIT_BURST=3
SEARXNG_MAX_RETRIES=4
SEARXNG_BACKOFF_BASE=1.0
SEARXNG_BACKOFF_MAX=30.0
SEARXNG_TIMEOUT=15.0

# --- Search result cache ---
# Cache search results per day so re-runs don't re-hit the backend. true|false
SEARCH_CACHE=true
# Where to store the daily cache (default: <project>/.search_cache)
SEARCH_CACHE_DIR=

# --- Agent guardrails ---
MAX_ITERATIONS=8
# Allow one search per holding without hitting the cap (raise for large portfolios).
MAX_TOOL_CALLS=60
# Throttling spaces searches out, so a full run needs more wall-clock time.
RUN_TIMEOUT_SECONDS=600
FETCH_CHAR_BUDGET=8000

# --- Delivery ---
# email (default) sends via SMTP | file writes summary-<date>.md to OUTPUT_DIR
DELIVERY_MODE=email
# Directory for the summary file when DELIVERY_MODE=file (defaults to project root)
OUTPUT_DIR=

# --- Email delivery (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
